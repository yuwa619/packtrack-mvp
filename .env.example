PROJECT_NAME=PackTrack MVP
ENVIRONMENT=local

# API/worker
API_HOST=0.0.0.0
API_PORT=8000
WORKER_PORT=8001

# Postgres
POSTGRES_DB=packtrack
POSTGRES_USER=packtrack
POSTGRES_PASSWORD=packtrack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://packtrack:packtrack@postgres:5432/packtrack

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_INTERNAL_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_BUCKET_RAW=raw-uploads
MINIO_BUCKET_PREPROCESSED=preprocessed
MINIO_BUCKET_REPORTS=reports
MINIO_FORCE_LOCAL=false
MINIO_ALLOW_LOCAL_FALLBACK=true
MINIO_FALLBACK_DIR=data/minio_stub

# Confidence thresholds
OCR_CONFIDENCE_THRESHOLD=0.70
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.85

# Ingestion
MAX_UPLOAD_SIZE_BYTES=52428800
ZIP_MAX_FILE_COUNT=200
ZIP_MAX_TOTAL_UNCOMPRESSED_BYTES=262144000
UPLOAD_URL_EXPIRY_SECONDS=900
PROCESSING_QUEUE_NAME=packtrack:queue:preprocess
PIPELINE_STAGE_MAX_ATTEMPTS=3
ENABLE_DEMO_ENDPOINTS=false
CORS_ORIGINS=http://localhost:5173
NER_ENABLED=false
NER_MODEL_PATH=data/models/spacy_ner/latest/model-best

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
FRONTEND_PORT=5173
